generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  CITIZEN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

enum ApplicationStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

model User {
  id              String      @id @default(cuid())
  fullName        String
  mobile          String      @unique
  email           String      @unique
  passwordHash    String
  role            Role
  status          UserStatus  @default(PENDING)
  state           String?
  district        String?
  address         String?
  aadharNumber    String?
  panNumber       String?
  education       String?
  experience      String?
  remarks         String?
  otpCode         String?
  otpExpiresAt    DateTime?
  otpVerified     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  applications    Application[]
  notifications   Notification[]
  aiLogs          AISyncLog[] @relation("AILogAuthor")
}

model Scheme {
  id                  String         @id @default(cuid())
  schemeId            String         @unique
  schemeName          String
  description         String
  benefits            String
  eligibility         String
  documentsRequired   String
  applicationProcess  String
  officialLink        String
  state               String
  department          String
  category            String
  incomeLimit         String?
  gender              String?
  ageMin              Int?
  ageMax              Int?
  lastUpdated         DateTime       @default(now())
  applications        Application[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Application {
  id              String            @id @default(cuid())
  citizenId       String
  agentId         String
  schemeId        String
  status          ApplicationStatus @default(SUBMITTED)
  documents       Json?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  citizen         User              @relation(fields: [citizenId], references: [id])
  agent           User              @relation(fields: [agentId], references: [id])
  scheme          Scheme            @relation(fields: [schemeId], references: [id])
}

model Notification {
  id            String    @id @default(cuid())
  userId        String
  channel       String
  message       String
  sentAt        DateTime  @default(now())
  read          Boolean   @default(false)

  user          User      @relation(fields: [userId], references: [id])
}

model AISyncLog {
  id              String   @id @default(cuid())
  source           String
  action           String
  changesDetected  Boolean
  summary          String
  runAt            DateTime @default(now())
  initiatedById    String?

  initiatedBy      User?   @relation("AILogAuthor", fields: [initiatedById], references: [id])
}
